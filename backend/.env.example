# ─── Kaltura Avatar ────────────────────────────────────────────────────────────
# Your Kaltura Session key. NEVER commit the real value. NEVER send to frontend.
KALTURA_KS=your_kaltura_session_key_here

# Optional: override the Kaltura Avatar API base URL
KALTURA_AVATAR_BASE_URL=https://api.avatar.us.kaltura.ai/v1/avatar-session

# Optional: default avatar/voice if the frontend does not supply them
DEFAULT_AVATAR_ID=your_default_avatar_id_here
DEFAULT_VOICE_ID=your_default_voice_id_here

# ─── ADK Agent ─────────────────────────────────────────────────────────────────
# Port the Python ADK server listens on (adk api_server backend/agent)
ADK_PORT=8000

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# Comma-separated list of frontend origins allowed by CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
